<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard · Cognifyz L4</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="dashboard-page-body">

    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-lightning-charge-fill text-warning"></i> Cognifyz
                <span class="badge bg-warning text-dark ms-2 small">Level 4</span>
            </a>
            <div class="ms-auto d-flex align-items-center gap-3">
                <span class="text-white-50">
                    <i class="bi bi-person-circle me-1"></i><%= user.name %>
                </span>
                <button class="btn btn-outline-light btn-sm" id="logoutBtn">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
            </div>
        </div>
    </nav>

    <div class="dashboard-page-layout">

        <aside class="dashboard-sidebar">
            <div class="dashboard-sidebar-item active" onclick="loadSection('users')"   id="nav-users">
                <i class="bi bi-people-fill"></i><span>All Users</span>
            </div>
            <div class="dashboard-sidebar-item" onclick="loadSection('weather')"  id="nav-weather">
                <i class="bi bi-cloud-sun-fill"></i><span>Weather API</span>
            </div>
            <div class="dashboard-sidebar-item" onclick="loadSection('profile')"  id="nav-profile">
                <i class="bi bi-person-fill"></i><span>My Profile</span>
            </div>
            <div class="dashboard-sidebar-item" onclick="loadSection('cache')"    id="nav-cache">
                <i class="bi bi-lightning-fill"></i><span>Cache Stats</span>
            </div>
            <div class="dashboard-sidebar-item" onclick="loadSection('api')"      id="nav-api">
                <i class="bi bi-braces"></i><span>API Explorer</span>
            </div>
        </aside>

        <main class="dashboard-main-content p-4">

            <%# Users Section %>
            <div class="dashboard-content-section active-dashboard-section" id="section-users">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0">All Registered Users</h4>
                    <button class="btn btn-primary btn-sm" onclick="fetchUsers()">
                        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                    </button>
                </div>
                <div id="usersGrid">
                    <div class="text-center py-5 text-muted">
                        <div class="spinner-border text-primary mb-3"></div>
                        <p>Loading users...</p>
                    </div>
                </div>
            </div>

            <%# Weather Section — Task 7 %>
            <div class="dashboard-content-section" id="section-weather">
                <h4 class="fw-bold mb-2">Weather API</h4>
                <p class="text-muted mb-4">
                    Live weather via OpenWeatherMap · Results cached for 5 minutes
                </p>

                <div class="row justify-content-center">
                    <div class="col-lg-6">
                        <div class="weather-search-container-card p-4 mb-4">
                            <label class="form-label fw-semibold">Search City</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="cityInput"
                                       placeholder="e.g. Mumbai, London, Tokyo">
                                <button class="btn btn-primary fw-bold" id="weatherBtn">
                                    <i class="bi bi-search me-1"></i>Search
                                </button>
                            </div>
                            <div class="d-flex gap-2 mt-3 flex-wrap">
                                <button class="btn btn-outline-secondary btn-sm quick-city" data-city="Mumbai">Mumbai</button>
                                <button class="btn btn-outline-secondary btn-sm quick-city" data-city="London">London</button>
                                <button class="btn btn-outline-secondary btn-sm quick-city" data-city="Tokyo">Tokyo</button>
                                <button class="btn btn-outline-secondary btn-sm quick-city" data-city="New York">New York</button>
                                <button class="btn btn-outline-secondary btn-sm quick-city" data-city="Lucknow">Lucknow</button>
                            </div>
                        </div>

                        <div id="weatherResult"></div>
                    </div>
                </div>
            </div>

            <%# Profile Section %>
            <div class="dashboard-content-section" id="section-profile">
                <h4 class="fw-bold mb-4">My Profile</h4>
                <div class="row">
                    <div class="col-lg-6">
                        <div class="user-profile-card p-4">
                            <div class="text-center mb-4">
                                <div class="user-profile-avatar mx-auto mb-3">
                                    <%= user.name.charAt(0).toUpperCase() %>
                                </div>
                                <h5 class="fw-bold"><%= user.name %></h5>
                                <p class="text-muted"><%= user.email %></p>
                            </div>
                            <div id="profileAlert"></div>
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Full Name</label>
                                    <input type="text" class="form-control" id="edit-name" value="<%= user.name %>">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Age</label>
                                    <input type="number" class="form-control" id="edit-age" placeholder="Your age">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Phone</label>
                                    <input type="text" class="form-control" id="edit-phone" placeholder="10-digit">
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Gender</label>
                                    <select class="form-select" id="edit-gender">
                                        <option value="">-- Select --</option>
                                        <option value="male">Male</option>
                                        <option value="female">Female</option>
                                        <option value="other">Other</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-primary w-100 fw-bold form-submit-button" id="updateBtn">
                                        Update Profile <i class="bi bi-check-circle ms-1"></i>
                                    </button>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-outline-danger w-100" id="deleteBtn">
                                        <i class="bi bi-trash me-1"></i>Delete My Account
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <%# Cache Stats — Task 8 %>
            <div class="dashboard-content-section" id="section-cache">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-bold mb-1">Cache Statistics</h4>
                        <p class="text-muted mb-0">Server-side caching via node-cache · TTL: 10 minutes</p>
                    </div>
                    <button class="btn btn-primary btn-sm" onclick="fetchCacheStats()">
                        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                    </button>
                </div>
                <div id="cacheStats">
                    <div class="text-center py-4 text-muted">
                        <div class="spinner-border text-primary"></div>
                    </div>
                </div>
            </div>

            <%# API Explorer %>
            <div class="dashboard-content-section" id="section-api">
                <h4 class="fw-bold mb-2">API Explorer</h4>
                <p class="text-muted mb-4">Live REST API — click to test endpoints directly</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="api-endpoint-card p-4">
                            <span class="method-badge get">GET</span>
                            <code class="ms-2">/api/users</code>
                            <p class="text-muted small mt-2 mb-2">Fetch all users (cached)</p>
                            <span class="badge bg-warning text-dark me-2">JWT Protected</span>
                            <span class="badge bg-info text-dark">Cached</span>
                            <br>
                            <button class="btn btn-outline-primary btn-sm mt-2" onclick="testApi('GET','/api/users')">
                                Try it <i class="bi bi-play-fill"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="api-endpoint-card p-4">
                            <span class="method-badge get">GET</span>
                            <code class="ms-2">/api/weather/:city</code>
                            <p class="text-muted small mt-2 mb-2">External API + 5min cache</p>
                            <span class="badge bg-warning text-dark me-2">JWT Protected</span>
                            <span class="badge bg-success">External API</span>
                            <br>
                            <button class="btn btn-outline-primary btn-sm mt-2" onclick="testApi('GET','/api/weather/London')">
                                Try London <i class="bi bi-play-fill"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="api-endpoint-card p-4">
                            <span class="method-badge put">PUT</span>
                            <code class="ms-2">/api/users/:id</code>
                            <p class="text-muted small mt-2 mb-2">Update profile + invalidate cache</p>
                            <span class="badge bg-warning text-dark">JWT Protected</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="api-endpoint-card p-4">
                            <span class="method-badge get">GET</span>
                            <code class="ms-2">/api/cache/stats</code>
                            <p class="text-muted small mt-2 mb-2">View cache hit/miss stats</p>
                            <span class="badge bg-warning text-dark me-2">JWT Protected</span>
                            <br>
                            <button class="btn btn-outline-primary btn-sm mt-2" onclick="testApi('GET','/api/cache/stats')">
                                Try it <i class="bi bi-play-fill"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="mt-4">
                    <h6 class="fw-bold">API Response</h6>
                    <pre class="api-response-container" id="apiResponse">// Click "Try it" to see live response</pre>
                </div>
            </div>

        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const USER_ID = '<%= user.id %>';

        function loadSection(name) {
            document.querySelectorAll('.dashboard-content-section').forEach(s => s.classList.remove('active-dashboard-section'));
            document.querySelectorAll('.dashboard-sidebar-item').forEach(s => s.classList.remove('active'));
            document.getElementById('section-' + name).classList.add('active-dashboard-section');
            document.getElementById('nav-' + name).classList.add('active');
            if (name === 'users')  fetchUsers();
            if (name === 'cache')  fetchCacheStats();
        }

        // ── Fetch Users ──
        async function fetchUsers() {
            document.getElementById('usersGrid').innerHTML = `
                <div class="text-center py-5 text-muted">
                    <div class="spinner-border text-primary mb-3"></div><p>Loading...</p>
                </div>`;
            try {
                const res  = await fetch('/api/users');
                const data = await res.json();
                if (!data.success) throw new Error();

                const sourceBadge = data.source === 'cache'
                    ? '<span class="badge bg-info text-dark ms-2">⚡ From Cache</span>'
                    : '<span class="badge bg-secondary ms-2">🗄 From Database</span>';

                if (data.users.length === 0) {
                    document.getElementById('usersGrid').innerHTML =
                        `<div class="text-center py-5 text-muted"><i class="bi bi-inbox display-3"></i><p class="mt-3">No users yet.</p></div>`;
                    return;
                }

                document.getElementById('usersGrid').innerHTML = `
                    <p class="text-muted small mb-3">${data.count} users found ${sourceBadge}</p>
                    <div class="row g-3">
                        ${data.users.map(u => `
                            <div class="col-md-6 col-lg-4">
                                <div class="submission-record-card p-3 h-100">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="user-avatar-circle me-3">${u.name.charAt(0).toUpperCase()}</div>
                                        <div>
                                            <h6 class="mb-0 fw-bold">${u.name}</h6>
                                            <small class="text-muted">${u.email}</small>
                                        </div>
                                    </div>
                                    ${u.phone  ? `<p class="mb-1 small"><i class="bi bi-telephone me-1 text-primary"></i>${u.phone}</p>` : ''}
                                    ${u.gender ? `<p class="mb-1 small"><i class="bi bi-person me-1 text-primary"></i>${u.gender}${u.age ? ' · Age ' + u.age : ''}</p>` : ''}
                                    <small class="text-muted">Joined: ${new Date(u.createdAt).toLocaleDateString()}</small>
                                </div>
                            </div>`).join('')}
                    </div>`;
            } catch {
                document.getElementById('usersGrid').innerHTML =
                    `<div class="alert alert-danger">Failed to load users.</div>`;
            }
        }

        // ── Weather ──
        async function fetchWeather(city) {
            const result = document.getElementById('weatherResult');
            result.innerHTML = `<div class="text-center py-4"><div class="spinner-border text-primary"></div></div>`;

            try {
                const res  = await fetch(`/api/weather/${encodeURIComponent(city)}`);
                const data = await res.json();

                if (!data.success) {
                    result.innerHTML = `<div class="alert alert-danger">${data.message}</div>`;
                    return;
                }

                const w = data.weather;
                const sourceBadge = data.source === 'cache'
                    ? '<span class="badge bg-info text-dark">⚡ Cached</span>'
                    : '<span class="badge bg-secondary">🌐 Live API</span>';

                result.innerHTML = `
                    <div class="weather-display-card p-4 text-center">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div></div>
                            ${sourceBadge}
                        </div>
                        <img src="https://openweathermap.org/img/wn/${w.icon}@2x.png"
                             alt="${w.description}" width="80">
                        <h2 class="fw-bold mt-2">${w.temp}°C</h2>
                        <h5 class="text-muted text-capitalize">${w.description}</h5>
                        <h4 class="fw-bold">${w.city}, ${w.country}</h4>
                        <div class="row g-3 mt-3">
                            <div class="col-4">
                                <div class="weather-statistic-box">
                                    <i class="bi bi-thermometer-half text-danger"></i>
                                    <p class="mb-0 fw-bold">${w.feels_like}°C</p>
                                    <small class="text-muted">Feels Like</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="weather-statistic-box">
                                    <i class="bi bi-droplet-fill text-primary"></i>
                                    <p class="mb-0 fw-bold">${w.humidity}%</p>
                                    <small class="text-muted">Humidity</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="weather-statistic-box">
                                    <i class="bi bi-wind text-success"></i>
                                    <p class="mb-0 fw-bold">${w.wind} m/s</p>
                                    <small class="text-muted">Wind</small>
                                </div>
                            </div>
                        </div>
                    </div>`;
            } catch {
                result.innerHTML = `<div class="alert alert-danger">Network error.</div>`;
            }
        }

        document.getElementById('weatherBtn').addEventListener('click', () => {
            const city = document.getElementById('cityInput').value.trim();
            if (city) fetchWeather(city);
        });

        document.getElementById('cityInput').addEventListener('keydown', e => {
            if (e.key === 'Enter') {
                const city = e.target.value.trim();
                if (city) fetchWeather(city);
            }
        });

        document.querySelectorAll('.quick-city').forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById('cityInput').value = btn.dataset.city;
                fetchWeather(btn.dataset.city);
            });
        });

        // ── Cache Stats ──
        async function fetchCacheStats() {
            document.getElementById('cacheStats').innerHTML =
                `<div class="text-center py-4"><div class="spinner-border text-primary"></div></div>`;
            try {
                const res  = await fetch('/api/cache/stats');
                const data = await res.json();
                const s    = data.stats;

                document.getElementById('cacheStats').innerHTML = `
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <div class="cache-statistics-card text-center p-3">
                                <h3 class="fw-bold text-primary">${s.hits}</h3>
                                <p class="text-muted mb-0">Cache Hits</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="cache-statistics-card text-center p-3">
                                <h3 class="fw-bold text-danger">${s.misses}</h3>
                                <p class="text-muted mb-0">Cache Misses</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="cache-statistics-card text-center p-3">
                                <h3 class="fw-bold text-success">${s.keys}</h3>
                                <p class="text-muted mb-0">Cached Keys</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="cache-statistics-card text-center p-3">
                                <h3 class="fw-bold text-warning">${s.ksize + s.vsize}</h3>
                                <p class="text-muted mb-0">Memory (bytes)</p>
                            </div>
                        </div>
                    </div>
                    <h6 class="fw-bold mb-3">Active Cache Keys</h6>
                    ${data.cachedKeys.length === 0
                        ? `<p class="text-muted">No active cache keys.</p>`
                        : `<div class="d-flex flex-wrap gap-2">
                            ${data.cachedKeys.map(k =>
                                `<span class="badge bg-primary">${k}</span>`
                            ).join('')}
                           </div>`}`;
            } catch {
                document.getElementById('cacheStats').innerHTML =
                    `<div class="alert alert-danger">Failed to load cache stats.</div>`;
            }
        }

        // ── Profile Update ──
        document.getElementById('updateBtn').addEventListener('click', async () => {
            const btn = document.getElementById('updateBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Updating...';

            try {
                const res  = await fetch(`/api/users/${USER_ID}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        name:   document.getElementById('edit-name').value,
                        age:    document.getElementById('edit-age').value,
                        phone:  document.getElementById('edit-phone').value,
                        gender: document.getElementById('edit-gender').value
                    })
                });
                const data = await res.json();
                const box  = document.getElementById('profileAlert');
                box.innerHTML = data.success
                    ? `<div class="alert alert-success py-2">✅ ${data.message}</div>`
                    : `<div class="alert alert-danger py-2">${data.message}</div>`;
            } catch {
                document.getElementById('profileAlert').innerHTML =
                    `<div class="alert alert-danger py-2">Network error.</div>`;
            }

            btn.disabled = false;
            btn.innerHTML = 'Update Profile <i class="bi bi-check-circle ms-1"></i>';
        });

        // ── Delete Account ──
        document.getElementById('deleteBtn').addEventListener('click', async () => {
            if (!confirm('Permanently delete your account?')) return;
            const res  = await fetch(`/api/users/${USER_ID}`, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) window.location.href = '/';
        });

        // ── API Explorer ──
        async function testApi(method, url) {
            const pre = document.getElementById('apiResponse');
            pre.textContent = 'Loading...';
            try {
                const res  = await fetch(url, { method });
                const data = await res.json();
                pre.textContent = JSON.stringify(data, null, 2);
            } catch {
                pre.textContent = 'Error fetching response.';
            }
        }

        // ── Logout ──
        document.getElementById('logoutBtn').addEventListener('click', async () => {
            await fetch('/auth/logout', { method: 'POST' });
            window.location.href = '/';
        });

        fetchUsers();
    </script>
</body>
</html>