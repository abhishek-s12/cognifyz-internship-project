<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard · Cognifyz</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="dashboard-body">

    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-lightning-charge-fill text-warning"></i> Cognifyz
            </a>
            <div class="ms-auto d-flex align-items-center gap-3">
                <span class="text-white-50">
                    <i class="bi bi-person-circle me-1"></i> <%= user.name %>
                </span>
                <button class="btn btn-outline-light btn-sm" id="logoutBtn">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
            </div>
        </div>
    </nav>

    <div class="dashboard-layout">

        <%# Sidebar %>
        <aside class="sidebar">
            <div class="sidebar-item active" onclick="loadSection('users')" id="nav-users">
                <i class="bi bi-people-fill"></i><span>All Users</span>
            </div>
            <div class="sidebar-item" onclick="loadSection('profile')" id="nav-profile">
                <i class="bi bi-person-fill"></i><span>My Profile</span>
            </div>
            <div class="sidebar-item" onclick="loadSection('api')" id="nav-api">
                <i class="bi bi-braces"></i><span>API Explorer</span>
            </div>
        </aside>

        <%# Main Content %>
        <main class="dash-main p-4">

            <%# Users Section %>
            <div class="dash-section active-dash" id="section-users">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0">All Registered Users</h4>
                    <button class="btn btn-primary btn-sm" onclick="fetchUsers()">
                        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                    </button>
                </div>
                <div id="usersGrid">
                    <div class="text-center py-5 text-muted">
                        <div class="spinner-border text-primary mb-3"></div>
                        <p>Loading users...</p>
                    </div>
                </div>
            </div>

            <%# Profile Section %>
            <div class="dash-section" id="section-profile">
                <h4 class="fw-bold mb-4">My Profile</h4>
                <div class="row">
                    <div class="col-lg-6">
                        <div class="profile-card p-4">
                            <div class="text-center mb-4">
                                <div class="profile-avatar mx-auto mb-3">
                                    <%= user.name.charAt(0).toUpperCase() %>
                                </div>
                                <h5 class="fw-bold"><%= user.name %></h5>
                                <p class="text-muted"><%= user.email %></p>
                            </div>
                            <div id="profileAlert"></div>
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Full Name</label>
                                    <input type="text" class="form-control" id="edit-name" value="<%= user.name %>">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Age</label>
                                    <input type="number" class="form-control" id="edit-age" placeholder="Your age">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Phone</label>
                                    <input type="text" class="form-control" id="edit-phone" placeholder="10-digit number">
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Gender</label>
                                    <select class="form-select" id="edit-gender">
                                        <option value="">-- Select --</option>
                                        <option value="male">Male</option>
                                        <option value="female">Female</option>
                                        <option value="other">Other</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-primary w-100 fw-bold submit-btn" id="updateBtn">
                                        Update Profile <i class="bi bi-check-circle ms-1"></i>
                                    </button>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-outline-danger w-100" id="deleteBtn">
                                        <i class="bi bi-trash me-1"></i>Delete My Account
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <%# API Explorer Section %>
            <div class="dash-section" id="section-api">
                <h4 class="fw-bold mb-4">API Explorer</h4>
                <p class="text-muted mb-4">Live REST API endpoints — click to test them directly.</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="api-card p-4">
                            <span class="method-badge get">GET</span>
                            <code class="ms-2">/api/users</code>
                            <p class="text-muted small mt-2 mb-3">Fetch all registered users</p>
                            <button class="btn btn-outline-primary btn-sm" onclick="testApi('GET','/api/users')">
                                Try it <i class="bi bi-play-fill"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="api-card p-4">
                            <span class="method-badge get">GET</span>
                            <code class="ms-2">/api/users/:id</code>
                            <p class="text-muted small mt-2 mb-3">Fetch a single user by ID</p>
                            <button class="btn btn-outline-primary btn-sm" onclick="testApi('GET','/api/users/<%= user.id %>')">
                                Try with my ID <i class="bi bi-play-fill"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="api-card p-4">
                            <span class="method-badge post">POST</span>
                            <code class="ms-2">/auth/register</code>
                            <p class="text-muted small mt-2 mb-3">Register a new user</p>
                            <span class="badge bg-secondary">Auth not required</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="api-card p-4">
                            <span class="method-badge delete">DELETE</span>
                            <code class="ms-2">/api/users/:id</code>
                            <p class="text-muted small mt-2 mb-3">Delete your own account (JWT protected)</p>
                            <span class="badge bg-warning text-dark">Protected Route</span>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <h6 class="fw-bold">API Response</h6>
                    <pre class="api-response" id="apiResponse">// Click "Try it" above to see a live response</pre>
                </div>
            </div>

        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const USER_ID = '<%= user.id %>';

        // ── Sidebar navigation ──
        function loadSection(name) {
            document.querySelectorAll('.dash-section').forEach(s => s.classList.remove('active-dash'));
            document.querySelectorAll('.sidebar-item').forEach(s => s.classList.remove('active'));
            document.getElementById('section-' + name).classList.add('active-dash');
            document.getElementById('nav-' + name).classList.add('active');
            if (name === 'users') fetchUsers();
        }

        // ── Fetch all users ──
        async function fetchUsers() {
            document.getElementById('usersGrid').innerHTML = `
                <div class="text-center py-5 text-muted">
                    <div class="spinner-border text-primary mb-3"></div><p>Loading...</p>
                </div>`;
            try {
                const res  = await fetch('/api/users');
                const data = await res.json();
                if (!data.success) throw new Error();

                if (data.users.length === 0) {
                    document.getElementById('usersGrid').innerHTML = `
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-inbox display-3"></i><p class="mt-3">No users yet.</p>
                        </div>`;
                    return;
                }

                document.getElementById('usersGrid').innerHTML = `
                    <div class="row g-3">
                        ${data.users.map(u => `
                            <div class="col-md-6 col-lg-4">
                                <div class="sub-card p-3 h-100">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="avatar me-3">${u.name.charAt(0).toUpperCase()}</div>
                                        <div>
                                            <h6 class="mb-0 fw-bold">${u.name}</h6>
                                            <small class="text-muted">${u.email}</small>
                                        </div>
                                    </div>
                                    ${u.phone   ? `<p class="mb-1 small"><i class="bi bi-telephone me-1 text-primary"></i>${u.phone}</p>` : ''}
                                    ${u.gender  ? `<p class="mb-1 small"><i class="bi bi-person me-1 text-primary"></i>${u.gender}${u.age ? ' · Age ' + u.age : ''}</p>` : ''}
                                    <small class="text-muted">Joined: ${new Date(u.createdAt).toLocaleDateString()}</small>
                                </div>
                            </div>`).join('')}
                    </div>`;
            } catch {
                document.getElementById('usersGrid').innerHTML = `
                    <div class="alert alert-danger">Failed to load users.</div>`;
            }
        }

        // ── Update profile ──
        document.getElementById('updateBtn').addEventListener('click', async () => {
            const btn = document.getElementById('updateBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Updating...';

            const body = {
                name:   document.getElementById('edit-name').value,
                age:    document.getElementById('edit-age').value,
                phone:  document.getElementById('edit-phone').value,
                gender: document.getElementById('edit-gender').value
            };

            try {
                const res  = await fetch(`/api/users/${USER_ID}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const data = await res.json();
                const alertBox = document.getElementById('profileAlert');
                if (data.success) {
                    alertBox.innerHTML = `<div class="alert alert-success py-2">✅ ${data.message}</div>`;
                } else {
                    alertBox.innerHTML = `<div class="alert alert-danger py-2">${data.message}</div>`;
                }
            } catch {
                document.getElementById('profileAlert').innerHTML =
                    `<div class="alert alert-danger py-2">Network error.</div>`;
            }

            btn.disabled = false;
            btn.innerHTML = 'Update Profile <i class="bi bi-check-circle ms-1"></i>';
        });

        // ── Delete account ──
        document.getElementById('deleteBtn').addEventListener('click', async () => {
            if (!confirm('Are you sure? This will permanently delete your account.')) return;
            const res  = await fetch(`/api/users/${USER_ID}`, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) window.location.href = '/';
        });

        // ── API Explorer ──
        async function testApi(method, url) {
            const pre = document.getElementById('apiResponse');
            pre.textContent = 'Loading...';
            try {
                const res  = await fetch(url, { method });
                const data = await res.json();
                pre.textContent = JSON.stringify(data, null, 2);
            } catch {
                pre.textContent = 'Error fetching response.';
            }
        }

        // ── Logout ──
        document.getElementById('logoutBtn').addEventListener('click', async () => {
            await fetch('/auth/logout', { method: 'POST' });
            window.location.href = '/';
        });

        // Load users on start
        fetchUsers();
    </script>
</body>
</html>