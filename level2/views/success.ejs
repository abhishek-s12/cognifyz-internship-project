<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="success-wrapper d-flex align-items-center justify-content-center min-vh-100">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="success-card text-center p-5">
                        <div class="success-icon-wrap mb-4">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                        <h2 class="fw-bold mb-2">You're Registered!</h2>
                        <p class="text-muted mb-4">Here's a summary of your submission</p>

                        <div class="summary-box text-start p-4 mb-4">
                            <p><i class="bi bi-person-fill me-2 text-primary"></i><strong>Name:</strong> <%= data.name %></p>
                            <p><i class="bi bi-envelope-fill me-2 text-primary"></i><strong>Email:</strong> <%= data.email %></p>
                            <p><i class="bi bi-calendar-fill me-2 text-primary"></i><strong>Age:</strong> <%= data.age %></p>
                            <p><i class="bi bi-telephone-fill me-2 text-primary"></i><strong>Phone:</strong> <%= data.phone %></p>
                            <p><i class="bi bi-gender-ambiguous me-2 text-primary"></i><strong>Gender:</strong> <%= data.gender %></p>
                            <p class="mb-0"><i class="bi bi-chat-fill me-2 text-primary"></i><strong>Message:</strong> <%= data.message %></p>
                        </div>

                        <a href="/" class="btn btn-primary px-5 py-2 fw-bold">
                            <i class="bi bi-arrow-left me-2"></i>Go Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>